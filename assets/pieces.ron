        (shape: [(0, 0), (1, 0), (0, 1)], color: "BLUE", points: 6, effects: []),
        (shape: [(0, 0), (1, 0), (0, 1)], color: "GREEN", points: 6, effects: []),

        // ═══════════════════════════════════════════════════════════
        // Size 4 – Dynamic pieces (each with all four effects)
        // ═══════════════════════════════════════════════════════════

        // Straight Tetromino (I)
        (
            shape: [(0, 0), (1, 0), (2, 0), (3, 0)],
            color: "IGNORED",
            points: 10,
            piece_type: dynamic,
            effects: [
                (condition: MatchesColor("RED"),   points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(3,-1),(4,-1),(-1,0),(4,0),(-1,1),(0,1),(1,1),(2,1),(3,1),(4,1)]),
                (condition: MatchesColor("BLUE"),  points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(3,-1),(4,-1),(-1,0),(4,0),(-1,1),(0,1),(1,1),(2,1),(3,1),(4,1)]),
                (condition: MatchesColor("GREEN"), points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(3,-1),(4,-1),(-1,0),(4,0),(-1,1),(0,1),(1,1),(2,1),(3,1),(4,1)]),
                (condition: IsEmpty,               points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(3,-1),(4,-1),(-1,0),(4,0),(-1,1),(0,1),(1,1),(2,1),(3,1),(4,1)]),
            ],
        ),

        // Square Tetromino (O)
        (
            shape: [(0, 0), (1, 0), (0, 1), (1, 1)],
            color: "IGNORED",
            points: 10,
            piece_type: dynamic,
            effects: [
                (condition: MatchesColor("RED"),   points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(-1,0),(2,0),(-1,1),(2,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: MatchesColor("BLUE"),  points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(-1,0),(2,0),(-1,1),(2,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: MatchesColor("GREEN"), points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(-1,0),(2,0),(-1,1),(2,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: IsEmpty,               points: 3, offsets: [(-1,-1),(0,-1),(1,-1),(2,-1),(-1,0),(2,0),(-1,1),(2,1),(-1,2),(0,2),(1,2),(2,2)]),
