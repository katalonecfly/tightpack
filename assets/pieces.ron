(
    pieces: [
        // ── Size 1: Monomino (1 cell) · 1 point ──
        (shape: [(0, 0)], color: "RED", points: 1, effects: []),
        (shape: [(0, 0)], color: "BLUE", points: 1, effects: []),
        (shape: [(0, 0)], color: "GREEN", points: 1, effects: []),

        // ── Size 2: Domino (2 cells) · 3 points ──
        (shape: [(0, 0), (1, 0)], color: "RED", points: 3, effects: []),
        (shape: [(0, 0), (1, 0)], color: "BLUE", points: 3, effects: []),
        (shape: [(0, 0), (1, 0)], color: "GREEN", points: 3, effects: []),

        // ── Size 3: Straight Tromino (I) · 6 points ──
        (shape: [(0, 0), (1, 0), (2, 0)], color: "RED", points: 6, effects: []),
        (shape: [(0, 0), (1, 0), (2, 0)], color: "BLUE", points: 6, effects: []),
        (shape: [(0, 0), (1, 0), (2, 0)], color: "GREEN", points: 6, effects: []),

        // ── Size 3: L‑Tromino (corner) · 6 points ──
