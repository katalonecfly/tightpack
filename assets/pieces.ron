            points: 10,
            piece_type: dynamic,
            effects: [
                (condition: MatchesColor("RED"),   points: 3, offsets: [(0,-1),(1,-1),(2,-1),(3,-1),(-1,0),(0,0),(3,0),(-1,1),(2,1),(3,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: MatchesColor("BLUE"),  points: 3, offsets: [(0,-1),(1,-1),(2,-1),(3,-1),(-1,0),(0,0),(3,0),(-1,1),(2,1),(3,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: MatchesColor("GREEN"), points: 3, offsets: [(0,-1),(1,-1),(2,-1),(3,-1),(-1,0),(0,0),(3,0),(-1,1),(2,1),(3,1),(-1,2),(0,2),(1,2),(2,2)]),
                (condition: IsEmpty,               points: 3, offsets: [(0,-1),(1,-1),(2,-1),(3,-1),(-1,0),(0,0),(3,0),(-1,1),(2,1),(3,1),(-1,2),(0,2),(1,2),(2,2)]),
